<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="using:Sentinel.ViewModels"
             xmlns:controls="using:Sentinel.Controls"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
             x:Class="Sentinel.Views.HomeView"
             x:DataType="viewModels:HomeViewModel">

    <Grid ColumnDefinitions="*,4,300">

        <!-- Left: filter + card grid -->
        <DockPanel Grid.Column="0">
            <TextBox DockPanel.Dock="Top"
                     Text="{Binding Filter}"
                     Watermark="Rechercher..."
                     Margin="8,8,8,4"/>
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Units}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:EquipmentUnitViewModel">
                            <Button Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Margin="6"
                                    Command="{Binding $parent[ItemsControl].((viewModels:HomeViewModel)DataContext).OpenDetailCommand}"
                                    CommandParameter="{Binding}">
                                <Border Background="{DynamicResource SentBrushSurface}"
                                        BorderBrush="{DynamicResource SentBrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Width="210">
                                    <StackPanel Spacing="8">

                                        <!-- Header : LED + nom/zone + badge -->
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <controls:StatusLed Grid.Column="0"
                                                                Status="{Binding Status}"
                                                                VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Margin="8,0,4,0">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource SentBrushForeground}"/>
                                                <TextBlock Text="{Binding Zone}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SentBrushForegroundMuted}"/>
                                            </StackPanel>
                                            <Border Grid.Column="2"
                                                    Background="{DynamicResource SentBrushStatusDegraded}"
                                                    CornerRadius="4"
                                                    Padding="4,2"
                                                    IsVisible="{Binding HasAlert}"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="⚠" FontSize="11"/>
                                            </Border>
                                        </Grid>

                                        <!-- Batterie -->
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Battery, StringFormat='Bat {0:F0}%'}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SentBrushForegroundMuted}"/>
                                            <controls:Sparkline Values="{Binding BatteryHistory}"
                                                                Stroke="{DynamicResource SentBrushSparklineBattery}"
                                                                Height="24"/>
                                        </StackPanel>

                                        <!-- Température -->
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Temperature, StringFormat='Temp {0:F1}°C'}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SentBrushForegroundMuted}"/>
                                            <controls:Sparkline Values="{Binding TemperatureHistory}"
                                                                Stroke="{DynamicResource SentBrushSparklineTemperature}"
                                                                Height="24"/>
                                        </StackPanel>

                                        <!-- Signal -->
                                        <StackPanel Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <controls:SignalBars Value="{Binding Signal}"
                                                                     VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Signal, StringFormat='{}{0}%'}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SentBrushForegroundMuted}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <controls:Sparkline Values="{Binding SignalHistory}"
                                                                Stroke="{DynamicResource SentBrushSparklineSignal}"
                                                                Height="24"/>
                                        </StackPanel>

                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" ResizeDirection="Columns"/>

        <!-- Right: detail panel -->
        <Border Grid.Column="2" Padding="12"
                Background="{DynamicResource SentBrushSurface}">
            <Panel>
                <TextBlock IsVisible="{Binding !HasSelection}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource SentBrushForegroundMuted}"
                           Text="Cliquer sur une carte"/>

                <ScrollViewer IsVisible="{Binding HasSelection}">
                    <StackPanel Spacing="10">
                        <TextBlock FontWeight="Bold" FontSize="16"
                                   Foreground="{DynamicResource SentBrushForeground}"
                                   Text="Détail"/>
                        <Separator/>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <controls:StatusLed Status="{Binding SelectedUnit.Status}"/>
                            <TextBlock Text="{Binding SelectedUnit.Status, StringFormat='Statut : {0}'}"
                                       Foreground="{DynamicResource SentBrushForeground}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="{Binding SelectedUnit.Battery, StringFormat='Batterie : {0:F0}%'}"
                                   Foreground="{DynamicResource SentBrushForeground}"/>
                        <controls:Sparkline Values="{Binding SelectedUnit.BatteryHistory}"
                                            Stroke="{DynamicResource SentBrushSparklineBattery}"/>

                        <TextBlock Text="{Binding SelectedUnit.Temperature, StringFormat='Température : {0:F2} °C'}"
                                   Foreground="{DynamicResource SentBrushForeground}"/>
                        <controls:Sparkline Values="{Binding SelectedUnit.TemperatureHistory}"
                                            Stroke="{DynamicResource SentBrushSparklineTemperature}"/>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <controls:SignalBars Value="{Binding SelectedUnit.Signal}"/>
                            <TextBlock Text="{Binding SelectedUnit.Signal, StringFormat='Signal : {0}%'}"
                                       Foreground="{DynamicResource SentBrushForeground}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <controls:Sparkline Values="{Binding SelectedUnit.SignalHistory}"
                                            Stroke="{DynamicResource SentBrushSparklineSignal}"/>

                        <TextBlock Text="{Binding SelectedUnit.LastSeen, StringFormat='Vu le : {0:HH:mm:ss}'}"
                                   Foreground="{DynamicResource SentBrushForegroundMuted}"/>

                        <Separator/>
                        <TextBlock FontWeight="Bold"
                                   Foreground="{DynamicResource SentBrushForeground}"
                                   Text="Édition"/>

                        <ContentControl Content="{Binding EditViewModel}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate x:DataType="viewModels:EquipmentEditViewModel">
                                    <StackPanel Spacing="8">
                                        <TextBox Text="{Binding Name, Mode=TwoWay}" Watermark="Nom"/>
                                        <TextBox Text="{Binding Zone, Mode=TwoWay}" Watermark="Zone"/>
                                        <Button Content="Enregistrer"
                                                Command="{Binding SaveCommand}"
                                                HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>

                    </StackPanel>
                </ScrollViewer>
            </Panel>
        </Border>

    </Grid>
</UserControl>

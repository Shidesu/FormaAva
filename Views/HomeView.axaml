<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="using:Sentinel.ViewModels"
             xmlns:controls="using:Sentinel.Controls"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="450"
             x:Class="Sentinel.Views.HomeView"
             x:DataType="viewModels:HomeViewModel">
    <Grid ColumnDefinitions="*,4,280">

        <!-- Left: filter + datagrid -->
        <DockPanel Grid.Column="0">
            <TextBox DockPanel.Dock="Top" Text="{Binding Filter}" Watermark="Rechercher..."/>
            <DataGrid ItemsSource="{Binding Units}"
                      SelectedItem="{Binding SelectedUnit}"
                      GridLinesVisibility="All"
                      CanUserSortColumns="True"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id"
                                        Binding="{Binding Id,
                        DataType=viewModels:EquipmentUnitViewModel}" />
                    <DataGridTextColumn Header="Name"
                                        Binding="{Binding Name,
                         DataType=viewModels:EquipmentUnitViewModel}" />
                    <DataGridTextColumn Header="Zone"
                                        Binding="{Binding Zone,
                         DataType=viewModels:EquipmentUnitViewModel}" />
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status,
                         DataType=viewModels:EquipmentUnitViewModel}" />
                    <DataGridTextColumn Header="Battery"
                                        Binding="{Binding Battery,
                                        DataType=viewModels:EquipmentUnitViewModel,
                                        StringFormat='Bat {0:F0}%'}" />
                    <DataGridTextColumn Header="Temperature"
                                        Binding="{Binding Temperature,
                                        DataType=viewModels:EquipmentUnitViewModel,
                                        StringFormat='{}{0:F2} °C'}" />
                    <DataGridTextColumn Header="Signal"
                                        Binding="{Binding Signal,
                                        DataType=viewModels:EquipmentUnitViewModel,
                                        StringFormat='Signal {0}%'}" />
                    <DataGridTextColumn Header="Last Seen"
                                        Binding="{Binding LastSeen,
                                        DataType=viewModels:EquipmentUnitViewModel,
                                        StringFormat='{}{0:HH:mm:ss}'}" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" ResizeDirection="Columns"/>

        <!-- Right: detail panel -->
        <Border Grid.Column="2" Padding="12">
            <Panel>
                <!-- Placeholder when nothing is selected -->
                <TextBlock IsVisible="{Binding !HasSelection}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Foreground="Gray"
                           Text="Sélectionner une ligne"/>

                <!-- Detail when a row is selected -->
                <StackPanel IsVisible="{Binding HasSelection}" Spacing="10">
                    <TextBlock FontWeight="Bold" FontSize="16" Text="Détail"/>
                    <Separator/>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <controls:StatusLed Status="{Binding SelectedUnit.Status}"/>
                        <TextBlock Text="{Binding SelectedUnit.Status, StringFormat='Statut : {0}'}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding SelectedUnit.Battery, StringFormat='Batterie : {0:F0}%'}"/>
                    <controls:Sparkline Values="{Binding SelectedUnit.BatteryHistory}"
                                        Stroke="#22DD77"/>

                    <TextBlock Text="{Binding SelectedUnit.Temperature, StringFormat='Température : {0:F2} °C'}"/>
                    <controls:Sparkline Values="{Binding SelectedUnit.TemperatureHistory}"
                                        Stroke="#FF8C00"/>

                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <controls:SignalBars Value="{Binding SelectedUnit.Signal}"/>
                        <TextBlock Text="{Binding SelectedUnit.Signal, StringFormat='Signal : {0}%'}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <controls:Sparkline Values="{Binding SelectedUnit.SignalHistory}"
                                        Stroke="#22AAFF"/>
                    <TextBlock Text="{Binding SelectedUnit.LastSeen, StringFormat='Vu le : {0:HH:mm:ss}'}"/>

                    <Separator/>
                    <TextBlock FontWeight="Bold" Text="Édition"/>

                    <ContentControl Content="{Binding EditViewModel}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate x:DataType="viewModels:EquipmentEditViewModel">
                                <StackPanel Spacing="8">
                                    <TextBox Text="{Binding Name, Mode=TwoWay}"
                                             Watermark="Nom"/>
                                    <TextBox Text="{Binding Zone, Mode=TwoWay}"
                                             Watermark="Zone"/>
                                    <Button Content="Enregistrer"
                                            Command="{Binding SaveCommand}"
                                            HorizontalAlignment="Right"/>
                                </StackPanel>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </StackPanel>
            </Panel>
        </Border>

    </Grid>
</UserControl>

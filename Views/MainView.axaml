<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="using:Sentinel.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Sentinel.Views.MainView"
             x:DataType="viewModels:MainViewModel"
             Background="{DynamicResource SentBrushBackground}">

    <DockPanel>
        <!-- Top bar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SentBrushSurface}"
                BorderBrush="{DynamicResource SentBrushBorder}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="← Retour"
                            Command="{Binding GoBackCommand}"
                            IsVisible="{Binding CanGoBack}"/>
                    <TextBlock Text="SENTINEL"
                               FontWeight="Bold"
                               FontSize="16"
                               Foreground="{DynamicResource SentBrushForeground}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="☀ / ☾"
                        Command="{Binding ToggleThemeCommand}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Page content with cross-fade transition -->
        <TransitioningContentControl Content="{Binding CurrentPage}">
            <TransitioningContentControl.PageTransition>
                <CrossFade Duration="0:0:0.2"/>
            </TransitioningContentControl.PageTransition>
        </TransitioningContentControl>
    </DockPanel>

</UserControl>
